# ─────────────────────────────────────────────
# TraDad — Environment Variables
# Copy this file to .env and fill in values.
# The dashboard runs without any of these set.
# ─────────────────────────────────────────────

# TELEGRAM ALERTS (optional — remove if not using)
# Get bot token from @BotFather on Telegram
# Get chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_MIN_CONFIDENCE=70

# DATABASE (default: tradad.db in project folder)
DB_PATH=tradad.db

# STOCK UNIVERSE (default: data/nifty500.csv)
STOCK_UNIVERSE_PATH=data/nifty500.csv

# DATA RETENTION
CANDLE_RETENTION_DAYS_INTRADAY=30
CANDLE_RETENTION_DAYS_DAILY=365

# ─────────────────────────────────────────────
# FUTURE: Broker API (uncomment when ready)
# ─────────────────────────────────────────────
# Option A — Motilal Oswal (email tradingapi@motilaloswal.com)
# MO_API_KEY=
# MO_CLIENT_ID=
# MO_PASSWORD=

# Option B — Shoonya / Finvasia
# SHOONYA_USER=
# SHOONYA_PASSWORD=
# SHOONYA_API_KEY=

# Option C — Angel One SmartAPI
# ANGEL_API_KEY=
# ANGEL_CLIENT_ID=
# ANGEL_PASSWORD=
# ANGEL_TOTP_SECRET=
